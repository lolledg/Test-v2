                    local victim = otherPart.Parent
                    if victim:FindFirstChild("Humanoid") then
                        return victim
                    end
                end
            end
        end
        
        -- Método 3: Buscar proximity prompts
        for _, prompt in pairs(Character:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") then
                -- Intentar encontrar víctima cercana
