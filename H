    -- FUNCIÓN PARA CREAR RAGDOLL EN CUALQUIER JUEGO
    local function ForceUniversalRagdoll(victim)
        if not victim or not victim.Parent then return false end
        
        print("[Universal] Forcing ragdoll on:", victim.Name)
        
        -- Método 1: Desactivar motor6D (funciona en la mayoría de juegos)
        for _, part in pairs(victim:GetDescendants()) do
            if part:IsA("Motor6D") then
                part.Enabled = false
            end
        end
        
        -- Método 2: PlatformStand (universal)
        if victim:FindFirstChild("Humanoid") then
            victim.Humanoid.PlatformStand = true
            
            -- Intentar todos los estados posibles
            pcall(function() victim.Humanoid:ChangeState(Enum.HumanoidStateType.Physics) end)
            pcall(function() victim.Humanoid:ChangeState(Enum.HumanoidStateType.FallingDown) end)
            pcall(function() victim.Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        end
        
        -- Método 3: Congelar partes
        for _, part in pairs(victim:GetChildren()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
                part.Velocity = Vector3.new(0, 0, 0)
                part.RotVelocity = Vector3.new(0, 0, 0)
            end
        end
        
        wait(0.1)
        return true
    end
    
    -- FUNCIÓN PARA FLOTAR EN CUALQUIER JUEGO
    local function UniversalFloat(victim, height)
        if not victim or not victim.Parent then return nil, nil end
        
        local root = victim:FindFirstChild("HumanoidRootPart") or victim:FindFirstChild("Torso") or victim:FindFirstChild("UpperTorso")
        if not root then return nil, nil end
        
        -- Limpiar controles antiguos
        local oldBP = root:FindFirstChild("UniversalBodyPos")
        local oldBG = root:FindFirstChild("UniversalBodyGyro")
        
        if oldBP then oldBP:Destroy() end
        if oldBG then oldBG:Destroy() end
        
        -- Crear BodyPosition
        local bodyPos = Instance.new("BodyPosition")
        bodyPos.Name = "UniversalBodyPos"
        bodyPos.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bodyPos.P = 30000
        bodyPos.D = 3000
        bodyPos.Position = root.Position + Vector3.new(0, height or 3, 0)
        bodyPos.Parent = root
        
        -- Crear BodyGyro
        local bodyGyro = Instance.new("BodyGyro")
        bodyGyro.Name = "UniversalBodyGyro"
        bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bodyGyro.P = 25000
        bodyGyro.CFrame = root.CFrame
        bodyGyro.Parent = root
        
        -- Partículas de efecto
        local particles = Instance.new("ParticleEmitter")
        particles.Name = "FloatParticles"
        particles.Size = NumberSequence.new(0.2)
        particles.Transparency = NumberSequence.new(0.5)
        particles.Color = ColorSequence.new(Color3.fromRGB(100, 200, 255))
        particles.Lifetime = NumberRange.new(0.5)
        particles.Rate = 25
        particles.Speed = NumberRange.new(2)
        particles.Acceleration = Vector3.new(0, 5, 0)
        particles.Parent = root
        
        return bodyPos, bodyGyro, particles
    end
    
    -- FUNCIÓN PARA DETECTAR AGARRE EN CUALQUIER JUEGO
    local function GetGrabbedVictim()
